ARG REGISTRY_IMAGE=ghcr.io/ma-riviere/docker-shiny
FROM ${REGISTRY_IMAGE}:base

# System dependencies for R packages + Chromium for shinytest2
USER root
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libcurl4-openssl-dev \
    zlib1g-dev \
    libxml2-dev \
    libfontconfig1-dev \
    libharfbuzz-dev \
    libfribidi-dev \
    libfreetype6-dev \
    libpng-dev \
    libtiff-dev \
    libjpeg-dev \
    chromium \
    chromium-driver \
    && apt-get clean && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

# Configure Chromium for shinytest2
ENV CHROMOTE_CHROME=/usr/bin/chromium
ENV SHINYTEST2_CHROMIUM_PATH=/usr/bin/chromium

# Install R dependencies
USER shiny
ENV RENV_PROFILE=tests
RUN R -e "source('renv/activate.R'); renv::restore()"

HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:3838/ || exit 1

# For docker run (ENTRYPOINT sets a "fixed" executable, to which args can be passed)
ENTRYPOINT ["/srv/shiny-server/docker-shiny.sh"]
