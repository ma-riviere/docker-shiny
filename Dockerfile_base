# syntax=docker/dockerfile:1

ARG DEBIAN_VERSION=trixie
ARG DEBIAN_NUMERIC=13
ARG R_VERSION=4.5.2

FROM debian:${DEBIAN_VERSION}-slim

# Locale setup
ENV LC_ALL=en_US.UTF-8
ENV LANG=en_US.UTF-8
ENV LANGUAGE=en_US.UTF-8

# Install locales, upgrade system, and install dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    locales \
    ca-certificates \
    wget \
    curl \
    libssl-dev \
    xtail \
    lsb-release \
    && localedef -i en_US -c -f UTF-8 -A /usr/share/locale/locale.alias en_US.UTF-8 \
    && apt-get upgrade -y

# Install R
ARG R_VERSION
ARG DEBIAN_NUMERIC
RUN wget https://cdn.posit.co/r/debian-${DEBIAN_NUMERIC}/pkgs/r-${R_VERSION}_1_amd64.deb \
    && apt-get update && apt-get install -y --no-install-recommends ./r-${R_VERSION}_1_amd64.deb \
    && ln -s /opt/R/${R_VERSION}/bin/R /usr/local/bin/R \
    && ln -s /opt/R/${R_VERSION}/bin/Rscript /usr/local/bin/Rscript \
    && rm r-${R_VERSION}_1_amd64.deb

# Install Shiny Server and cleanup apt cache (same layer to reduce image size)
ARG SHINY_SERVER_VERSION=1.5.23.1030
RUN wget https://download3.rstudio.org/ubuntu-20.04/x86_64/shiny-server-${SHINY_SERVER_VERSION}-amd64.deb \
    && apt-get update \
    && apt-get install -y --no-install-recommends ./shiny-server-${SHINY_SERVER_VERSION}-amd64.deb \
    && rm shiny-server-${SHINY_SERVER_VERSION}-amd64.deb \
    && apt-get clean && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

# Create shiny user and directories
RUN getent group shiny || groupadd -r shiny \
    && getent passwd shiny || useradd -r -g shiny -d /srv/shiny-server -s /sbin/nologin shiny \
    && mkdir -p /srv/shiny-server /var/log/shiny-server \
    && chown -R shiny:shiny /srv/shiny-server /var/log/shiny-server /var/lib/shiny-server \
    && chmod 755 /srv/shiny-server

# Create renv cache directory
RUN mkdir -p /opt/renv/cache && chown -R shiny:shiny /opt/renv

# R packages
## Copy local (repo) renv/ folder to /srv/shiny-server/
COPY --chown=shiny:shiny renv/ /srv/shiny-server/renv/
COPY --chmod=755 docker-shiny.sh /srv/shiny-server/docker-shiny.sh

# Install R dependencies
## Note: running as ROOT until buildkit inherits permissions
## - https://github.com/moby/buildkit/issues/1237
WORKDIR /srv/shiny-server
ENV RENV_PROFILE=base
ENV RENV_PATHS_CACHE=/opt/renv/cache
RUN --mount=type=cache,target=/opt/renv/cache \
    R -e "source('renv/activate.R'); renv::restore()"

USER shiny
EXPOSE 3838

# For docker run (CMD can be overriden)
CMD ["/srv/shiny-server/docker-shiny.sh"]
